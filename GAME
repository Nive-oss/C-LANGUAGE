#include <stdbool.h>
#include <math.h>
#include <stdlib.h>

#define EPSILON 1e-6

bool backtrack(double* nums, int size) {
    if (size == 1) {
        // Check if the remaining number is 24
        return fabs(nums[0] - 24.0) < EPSILON;
    }

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            if (i == j) continue;

            // Create a new list for the next recursion level
            double next_nums[4];
            int next_size = 0;
            for (int k = 0; k < size; k++) {
                if (k != i && k != j) {
                    next_nums[next_size++] = nums[k];
                }
            }

            // Try all 6 possible operations between nums[i] and nums[j]
            double results[6];
            int res_count = 0;
            
            results[res_count++] = nums[i] + nums[j];
            results[res_count++] = nums[i] - nums[j];
            results[res_count++] = nums[j] - nums[i];
            results[res_count++] = nums[i] * nums[j];
            if (fabs(nums[j]) > EPSILON) results[res_count++] = nums[i] / nums[j];
            if (fabs(nums[i]) > EPSILON) results[res_count++] = nums[j] / nums[i];

            for (int r = 0; r < res_count; r++) {
                next_nums[next_size] = results[r];
                if (backtrack(next_nums, next_size + 1)) return true;
            }
        }
    }
    return false;
}

bool judgePoint24(int* cards, int cardsSize) {
    double nums[4];
    for (int i = 0; i < 4; i++) {
        nums[i] = (double)cards[i];
    }
    return backtrack(nums, 4);
}
