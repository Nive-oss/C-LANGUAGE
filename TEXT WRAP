#include <stdio.h>

typedef long long ll;

// Function to check if a window of width 'W' can fit all words in 'K' lines
int canFit(int n, int k, int l[], ll W) {
    int lines = 1;
    ll current_width = 0;

    for (int i = 0; i < n; i++) {
        // If it's not the first word on the line, we need a space (length 1)
        ll space = (current_width == 0) ? 0 : 1;

        if (current_width + space + l[i] <= W) {
            // Fits on current line
            current_width += space + l[i];
        } else {
            // Move to next line
            lines++;
            current_width = l[i]; // Start new line with the current word
            if (lines > k) return 0;
        }
    }
    return lines <= k;
}

int main() {
    int n, k;
    if (scanf("%d %d", &n, &k) != 2) return 0;

    int l[n];
    ll max_word = 0;
    ll total_sum = 0;

    for (int i = 0; i < n; i++) {
        scanf("%d", &l[i]);
        if (l[i] > max_word) max_word = l[i];
        total_sum += l[i];
    }
    // Add spaces to total_sum for the upper bound calculation
    total_sum += (n - 1);

    ll low = max_word;
    ll high = total_sum;
    ll ans = total_sum;

    // Binary search for the minimum width
    while (low <= high) {
        ll mid = low + (high - low) / 2;
        if (canFit(n, k, l, mid)) {
            ans = mid;
            high = mid - 1; // Try smaller width
        } else {
            low = mid + 1;  // Need a larger width
        }
    }

    printf("%lld\n", ans);

    return 0;
}
