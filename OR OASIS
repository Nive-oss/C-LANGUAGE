#include <stdio.h>
#include <limits.h>

#define MAX_BITS 31

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    int a[n];
    int total_or = 0;
    int first_pos[MAX_BITS], last_pos[MAX_BITS];

    for (int i = 0; i < MAX_BITS; i++) {
        first_pos[i] = -1;
        last_pos[i] = -1;
    }

    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
        total_or |= a[i];
        for (int j = 0; j < MAX_BITS; j++) {
            if ((a[i] >> j) & 1) {
                if (first_pos[j] == -1) first_pos[j] = i;
                last_pos[j] = i;
            }
        }
    }

    // If total_or is 0, any single element (0) works as a subarray.
    if (total_or == 0) {
        printf("1 %d\n", n);
        return;
    }

    int bit_counts[MAX_BITS] = {0};
    int current_or = 0;
    int left = 0;
    int min_len = INT_MAX;
    int count = 0;

    for (int right = 0; right < n; right++) {
        // Add right element to window
        for (int j = 0; j < MAX_BITS; j++) {
            if ((a[right] >> j) & 1) {
                if (bit_counts[j] == 0) current_or |= (1 << j);
                bit_counts[j]++;
            }
        }

        // While window contains all bits of total_or
        while (current_or == total_or) {
            // Check if every bit in total_or also exists outside the window [left, right]
            int outside_ok = 1;
            for (int j = 0; j < MAX_BITS; j++) {
                if ((total_or >> j) & 1) {
                    // If the only occurrences of bit j are inside [left, right], it's invalid
                    if (!(first_pos[j] < left || last_pos[j] > right)) {
                        outside_ok = 0;
                        break;
                    }
                }
            }

            if (outside_ok) {
                int len = right - left + 1;
                if (len < min_len) {
                    min_len = len;
                    count = 1;
                } else if (len == min_len) {
                    count++;
                }
            }

            // Shrink window from left
            for (int j = 0; j < MAX_BITS; j++) {
                if ((a[left] >> j) & 1) {
                    bit_counts[j]--;
                    if (bit_counts[j] == 0) current_or &= ~(1 << j);
                }
            }
            left++;
        }
    }

    if (min_len == INT_MAX) {
        printf("-1\n");
    } else {
        printf("%d %d\n", min_len, count);
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
