#include <stdio.h>
int get_digit_sum(int n) {
    int sum = 0;
    while (n > 0) {
        sum += n % 10;
        n /= 10;
    }
    return sum;
}

long long solve(int N, int nums[]) {
    long long counts[100] = {0};
    long long total_pairs = 0;

    for (int i = 0; i < N; i++) {
        int sum = get_digit_sum(nums[i]);
        counts[sum]++;
    }

    for (int i = 0; i < 100; i++) {
        if (counts[i] >= 2) {
            total_pairs += (counts[i] * (counts[i] - 1)) / 2;
        }
    }

    return total_pairs;
}

int main() {
    int N;
    if (scanf("%d", &N) != 1) return 0;

    int nums[N];
    for (int i = 0; i < N; i++) {
        scanf("%d", &nums[i]);
    }

    printf("%lld\n", solve(N, nums));

    return 0;
}
