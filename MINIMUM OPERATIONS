#include <stdio.h>

long long solve() {
    int N;
    if (scanf("%d", &N) != 1) return -1;
    
    long long A[N];
    long long sum = 0;
    for (int i = 0; i < N; i++) {
        scanf("%lld", &A[i]);
        sum += A[i];
    }
    long long x = -sum;

    if (x < 0) {
        return -1;
    }

    long long sum_k_min = 0;
    for (int i = 0; i < N; i++) {
        if (A[i] < 0) {
            sum_k_min += (-A[i] + 1) / 2;
        }
    }

    if (sum_k_min <= x) {
        return x;
    } else {
        return -1;
    }
}

int main() {
    int T;
    if (scanf("%d", &T) != 1) return 0;
    while (T--) {
        printf("%lld\n", solve());
    }
    return 0;
}
