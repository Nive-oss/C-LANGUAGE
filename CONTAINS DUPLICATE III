#include <stdbool.h>
#include <stdlib.h>

// Simple Hash Map Node for Buckets
typedef struct Node {
    long key;
    long value;
    struct Node* next;
} Node;

typedef struct {
    int size;
    Node** table;
} HashMap;

HashMap* createMap(int size) {
    HashMap* map = (HashMap*)malloc(sizeof(HashMap));
    map->size = size;
    map->table = (Node**)calloc(size, sizeof(Node*));
    return map;
}

void put(HashMap* map, long key, long value) {
    int h = abs(key) % map->size;
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->key = key;
    newNode->value = value;
    newNode->next = map->table[h];
    map->table[h] = newNode;
}

bool contains(HashMap* map, long key, long* res) {
    int h = abs(key) % map->size;
    Node* curr = map->table[h];
    while (curr) {
        if (curr->key == key) {
            *res = curr->value;
            return true;
        }
        curr = curr->next;
    }
    return false;
}

void removeKey(HashMap* map, long key) {
    int h = abs(key) % map->size;
    Node* curr = map->table[h];
    Node* prev = NULL;
    while (curr) {
        if (curr->key == key) {
            if (prev) prev->next = curr->next;
            else map->table[h] = curr->next;
            free(curr);
            return;
        }
        prev = curr;
        curr = curr->next;
    }
}

long getBucketId(long val, long w) {
    return val < 0 ? (val + 1) / w - 1 : val / w;
}

bool containsNearbyAlmostDuplicate(int* nums, int numsSize, int indexDiff, int valueDiff) {
    if (valueDiff < 0) return false;
    
    // Bucket width is valueDiff + 1
    long w = (long)valueDiff + 1;
    HashMap* map = createMap(numsSize);

    for (int i = 0; i < numsSize; i++) {
        long m = getBucketId(nums[i], w);
        long res;

        // 1. Check current bucket
        if (contains(map, m, &res)) return true;
        // 2. Check adjacent buckets
        if (contains(map, m - 1, &res) && labs((long)nums[i] - res) <= valueDiff) return true;
        if (contains(map, m + 1, &res) && labs((long)nums[i] - res) <= valueDiff) return true;

        put(map, m, (long)nums[i]);

        // Maintain sliding window of size indexDiff
        if (i >= indexDiff) {
            removeKey(map, getBucketId(nums[i - indexDiff], w));
        }
    }
    return false;
}
