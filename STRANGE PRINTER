#include <string.h>
#include <stdio.h>

#define MIN(a, b) ((a) < (b) ? (a) : (b))

int strangePrinter(char * s) {
    int n = strlen(s);
    if (n == 0) return 0;

    // dp[i][j] will store the min turns to print substring s[i...j]
    int dp[101][101];

    // Base case: a single character takes 1 turn
    for (int i = 0; i < n; i++) {
        dp[i][i] = 1;
    }

    // len is the length of the interval we are currently calculating
    for (int len = 2; len <= n; len++) {
        for (int i = 0; i <= n - len; i++) {
            int j = i + len - 1;
            
            // Worst case: print the last character separately
            dp[i][j] = dp[i][j - 1] + 1;

            for (int k = i; k < j; k++) {
                // If the last character matches any previous character in the range,
                // we can potentially save a turn by printing them in the same stroke.
                if (s[k] == s[j]) {
                    // We split the interval at k. 
                    // dp[i][k] covers the first part (including the matching char).
                    // dp[k+1][j-1] covers everything in between.
                    dp[i][j] = MIN(dp[i][j], dp[i][k] + (k + 1 <= j - 1 ? dp[k + 1][j - 1] : 0));
                }
            }
        }
    }

    return dp[0][n - 1];
}
