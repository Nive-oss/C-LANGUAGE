#include <stdio.h>
#include <stdlib.h>

#define MAX(a, b) ((a) > (b) ? (a) : (b))

int largestRectangleArea(int* heights, int heightsSize) {
    // Stack to store indices
    int* stack = (int*)malloc(sizeof(int) * (heightsSize + 1));
    int top = -1;
    int maxArea = 0;

    for (int i = 0; i <= heightsSize; i++) {
        // Use a dummy height of 0 at the end to clear the stack
        int currentHeight = (i == heightsSize) ? 0 : heights[i];

        // While current bar is shorter than the bar at the stack top
        while (top != -1 && heights[stack[top]] >= currentHeight) {
            int h = heights[stack[top--]]; // Height of the rectangle
            
            // If stack is empty, width is 'i'. 
            // Otherwise, width is 'i - (index of new top) - 1'
            int w = (top == -1) ? i : i - stack[top] - 1;
            
            maxArea = MAX(maxArea, h * w);
        }
        stack[++top] = i;
    }

    free(stack);
    return maxArea;
}
