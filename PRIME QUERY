#include <stdio.h>

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    // We use long long for prefix sums and results to prevent overflow
    long long zero_pref[n], one_pref[n];
    int val;

    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        // Initialize current counts
        zero_pref[i] = (val == 0) ? 1 : 0;
        one_pref[i] = (val == 1) ? 1 : 0;

        // Build prefix sums
        if (i > 0) {
            zero_pref[i] += zero_pref[i - 1];
            one_pref[i] += one_pref[i - 1];
        }
    }

    int q;
    scanf("%d", &q);
    while (q--) {
        int l, r;
        scanf("%d %d", &l, &r);
        // Convert 1-based indexing to 0-based
        l--; r--;

        long long x = zero_pref[r];
        if (l > 0) x -= zero_pref[l - 1];

        long long y = one_pref[r];
        if (l > 0) y -= one_pref[l - 1];

        long long len = (r - l + 1);
        
        // Total possible pairs (i, j) where i < j
        long long total_pairs = (len * (len - 1)) / 2;
        
        // Invalid pairs are those where A[i] + A[j] < 2.
        // This only happens if:
        // 1. Both are 0: (0+0 = 0)
        // 2. One is 0 and the other is 1: (0+1 = 1)
        long long both_zero = (x * (x - 1)) / 2;
        long long zero_and_one = (x * y);
        
        long long result = total_pairs - both_zero - zero_and_one;
        printf("%lld\n", result);
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
