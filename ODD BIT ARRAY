#include <stdio.h>

#define MOD 1000000007

int count_set_bits_parity(int n) {
    int count = 0;
    while (n > 0) {
        n &= (n - 1);
        count++;
    }
    return count % 2;
}

void solve() {
    int N;
    if (scanf("%d", &N) != 1) return;

    long long sum0 = 1; 
    long long sum1 = 0;
    int current_prefix_xor = 0;
    long long last_dp = 0;

    for (int i = 0; i < N; i++) {
        int a;
        scanf("%d", &a);
        current_prefix_xor ^= a;

        if (count_set_bits_parity(current_prefix_xor) == 1) {
            
            last_dp = sum0;
            sum1 = (sum1 + last_dp) % MOD;
        } else {
           
            last_dp = sum1;
            sum0 = (sum0 + last_dp) % MOD;
        }
    }

    printf("%lld\n", last_dp);
}

int main() {
    int T;
    if (scanf("%d", &T) != 1) return 0;
    while (T--) {
        solve();
    }
    return 0;
}
