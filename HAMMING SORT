#include <stdio.h>
#include <stdlib.h>

// Structure to store the value and its Hamming Distance from K
typedef struct {
    int val;
    int dist;
} Element;

// Function to calculate Hamming Distance using XOR and popcount
int get_hamming_distance(int a, int k) {
    return __builtin_popcount(a ^ k);
}

// Comparator function for qsort
int compare(const void *a, const void *b) {
    Element *e1 = (Element *)a;
    Element *e2 = (Element *)b;

    // Primary sort: Ascending order of Hamming Distance
    if (e1->dist != e2->dist) {
        return e1->dist - e2->dist;
    }
    // Secondary sort (tie-breaker): Ascending numerical order
    return e1->val - e2->val;
}

void solve() {
    int n, k;
    if (scanf("%d %d", &n, &k) != 2) return;

    Element arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i].val);
        arr[i].dist = get_hamming_distance(arr[i].val, k);
    }

    // Sort the array based on the custom rules
    qsort(arr, n, sizeof(Element), compare);

    // Print the sorted values
    for (int i = 0; i < n; i++) {
        printf("%d%c", arr[i].val, (i == n - 1 ? '\n' : ' '));
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
