#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>

int calculate(char * s) {
    int n = strlen(s);
    int *stack = (int *)malloc(sizeof(int) * n);
    int top = -1;
    
    long long result = 0;
    long long number = 0;
    int sign = 1; // 1 for '+', -1 for '-'

    for (int i = 0; i < n; i++) {
        char c = s[i];

        if (isdigit(c)) {
            number = 10 * number + (c - '0');
        } else if (c == '+') {
            result += sign * number;
            number = 0;
            sign = 1;
        } else if (c == '-') {
            result += sign * number;
            number = 0;
            sign = -1;
        } else if (c == '(') {
            // Push current result and sign to stack
            stack[++top] = (int)result;
            stack[++top] = sign;
            // Reset for inner expression
            result = 0;
            sign = 1;
        } else if (c == ')') {
            result += sign * number;
            number = 0;
            // Pop sign first, then previous result
            int prev_sign = stack[top--];
            int prev_result = stack[top--];
            result = prev_result + (long long)prev_sign * result;
        }
    }
    
    result += sign * number; // Handle the last number
    free(stack);
    return (int)result;
}
