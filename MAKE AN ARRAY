#include <stdio.h>

long long solve(int N, int A[]) {
    if (N == 1) {
        return A[0] == 0 ? 0 : -1;
    }

    long long sum = 0;
    int max_val = 0;
    for (int i = 0; i < N; i++) {
        sum += A[i];
        if (A[i] > max_val) {
            max_val = A[i];
        }
    }
    if (sum % (N - 1) != 0) {
        return -1;
    }

    long long K = sum / (N - 1);
    if (K < max_val) {
        return -1;
    }

    return K;
}

int main() {
    int T;
    scanf("%d", &T);
    while (T--) {
        int N;
        scanf("%d", &N);
        int A[N];
        for (int i = 0; i < N; i++) {
            scanf("%d", &A[i]);
        }
        printf("%lld\n", solve(N, A));
    }
    return 0;
}
