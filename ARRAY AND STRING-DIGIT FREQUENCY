#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char s[1001];
    
    
    int frequencies[10] = {0};

    
    if (scanf("%s", s) != 1) return 0;

   
    for (int i = 0; s[i] != '\0'; i++) {
        
        
        if (s[i] >= '0' && s[i] <= '9') {
            
            
            int digitValue = s[i] - '0';
            frequencies[digitValue]++;
        }
    }

    
    for (int i = 0; i < 10; i++) {
        printf("%d", frequencies[i]);
        
        
        if (i < 9) {
            printf(" ");
        }
    }

    return 0;
}
