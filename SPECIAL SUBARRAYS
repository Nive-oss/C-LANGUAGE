#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MOD 1000000007

typedef struct Node {
    struct Node *child[2];
} Node;

Node* newNode() {
    Node* n = (Node*)calloc(1, sizeof(Node));
    return n;
}

void insert(Node* root, char* s) {
    Node* curr = root;
    for (int i = 0; s[i]; i++) {
        int b = s[i] - '0';
        if (!curr->child[b]) curr->child[b] = newNode();
        curr = curr->child[b];
    }
}

long long total_ans = 0;

/**
 * @param sum_in_prefix: Total count of special subarrays in the current prefix path.
 * @param last_zero_found: Boolean, true if we've seen at least one '0' in the path.
 * @param ones_since_zero: Count of '1's since the most recent '0'.
 */
void dfs(Node* u, long long sum_in_prefix, int last_zero_found, int ones_since_zero) {
    if (!u) return;

    // Add the sum of special subarrays found in THIS distinct prefix
    total_ans = (total_ans + sum_in_prefix) % MOD;

    // Transition for '0'
    if (u->child[0]) {
        // If we saw a '0' before, this '0' forms exactly ONE new special subarray
        // (the one starting at the immediate previous '0').
        long long next_sum = sum_in_prefix + (last_zero_found ? 1 : 0);
        dfs(u->child[0], next_sum, 1, 0);
    }

    // Transition for '1'
    if (u->child[1]) {
        // '1's do not end a special subarray, so the sum remains the same.
        dfs(u->child[1], sum_in_prefix, last_zero_found, ones_since_zero + 1);
    }
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    
    Node* root = newNode();
    char s[100005]; 
    for (int i = 0; i < n; i++) {
        scanf("%s", s);
        insert(root, s);
    }

    // Process all distinct prefixes starting from the Trie root.
    // The empty string (root) has 0 special subarrays.
    if (root->child[0]) dfs(root->child[0], 0, 1, 0);
    if (root->child[1]) dfs(root->child[1], 0, 0, 0);

    printf("%lld\n", total_ans);
    return 0;
}
