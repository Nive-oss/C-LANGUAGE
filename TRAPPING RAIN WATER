#include <stdio.h>

/**
 * Computes how much water can be trapped after raining.
 * Time Complexity: O(n) - We traverse the array once.
 * Space Complexity: O(1) - Only a few variables are used.
 */
int trap(int* height, int heightSize) {
    if (heightSize == 0) return 0;

    int left = 0, right = heightSize - 1;
    int left_max = 0, right_max = 0;
    int water_trapped = 0;

    while (left < right) {
        // We process the side with the smaller height, 
        // because the water trapped is limited by the shorter wall.
        if (height[left] < height[right]) {
            if (height[left] >= left_max) {
                // Update the maximum height from the left
                left_max = height[left];
            } else {
                // If current height is less than left_max, it can trap water
                water_trapped += left_max - height[left];
            }
            left++;
        } else {
            if (height[right] >= right_max) {
                // Update the maximum height from the right
                right_max = height[right];
            } else {
                // If current height is less than right_max, it can trap water
                water_trapped += right_max - height[right];
            }
            right--;
        }
    }

    return water_trapped;
}
