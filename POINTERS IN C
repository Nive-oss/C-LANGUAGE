#include <stdio.h>
#include <stdlib.h>

void update(int *a, int *b) {
    int val_a = *a;
    int val_b = *b;
    
    
    *a = val_a + val_b;
    
    
    *b = abs(val_a - val_b);
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    if (scanf("%d %d", &a, &b) == 2) {
        update(pa, pb);
        printf("%d\n%d", a, b);
    }

    return 0;
}

